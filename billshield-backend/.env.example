APP_NAME=BillShield UK API
APP_ENV=development
APP_VERSION=0.1.0
API_PREFIX=/api/v1

DATABASE_URL=sqlite:///./billshield_dev.db

FRONTEND_ORIGIN=http://localhost:5173
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10

MOCK_MODE=true

LOG_LEVEL=INFO
